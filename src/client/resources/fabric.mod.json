{
    "schemaVersion": 1,
    "id": "client-tools",
    "version": "${version}",
    "name": "Client Tools",
    "description": "A collection of client-side automation tools: /ccraft (auto-crafting chain), /ctimer (command scheduler), /cchat (quick chat), /cfly (flight), /csweep (area traversal), /csequence (sequence executor), /cbuy / /csell (shop automation), /cplacement (schematic mover), /cbow (arrow trajectory prediction), /criptide (riptide override), /cdoll (item 3D model).",
    "authors": [
        "Ohto-Ai"
    ],
    "contact": {
        "homepage": "https://www.curseforge.com/minecraft/mc-mods/client-tools",
        "sources": "https://github.com/ohto-ai/client-tools",
        "email": "ohtoai.choo@gmail.com",
        "issues": "https://github.com/ohto-ai/client-tools/issues"
    },
    "license": "MIT",
    "icon": "assets/client-tools/icon.png",
    "environment": "client",
    "entrypoints": {
        "client": [
            "indi.ohtoai.tool.client_tools.client.ClientToolsClient"
        ],
        "modmenu": [
            "indi.ohtoai.tool.client_tools.client.config.ModMenuIntegration"
        ]
    },
    "mixins": [
        {
            "config": "client-tools.client.mixins.json",
            "environment": "client"
        }
    ],
    "depends": {
        "fabricloader": ">=0.16.10",
        "minecraft": ">=1.21 <=1.21.8",
        "java": ">=21",
        "fabric-api": "*"
    },
    "recommends": {
        "modmenu": "*",
        "cloth-config": "*"
    },
    "suggests": {
        "litematica": "*"
    },
    
    "custom": {
        "modmenu": {
            "update_checker": true
        },
        "mc-publish": {
            "curseforge": 1575410,
            "modrinth": "zLOwSXvw"
        }
    }
}
